# Telegram Bot Token（由 @BotFather 获取）
TG_BOT_TOKEN=123456789:your_bot_token

# 接收提醒的 chat id（可用 @userinfobot 获取）
TG_CHAT_ID=123456789

# 提醒价格，支持多个，使用英文逗号分隔（示例：4.55,4.50,4.45）
ALERT_PRICES=4.55,4.50

# 轮询间隔区间（秒），每次检查后会在区间内随机等待
CHECK_INTERVAL_MIN_SECONDS=45
CHECK_INTERVAL_MAX_SECONDS=90

# 使用固定间隔：如果不设置上面的区间变量，可使用固定间隔
# CHECK_INTERVAL_SECONDS=60
